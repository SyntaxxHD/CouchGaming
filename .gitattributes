# Default: let git auto-detect text files, but normalize to LF in the repo.
* text=auto eol=lf

# Belt-and-suspenders: pin LF for everything Prettier owns so CI's
# `prettier --check` is stable on Windows runners.
*.ts        text eol=lf
*.mjs       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.sh        text eol=lf

# Binaries — never touched.
*.exe       binary
*.ico       binary
*.png       binary
*.jpg       binary
*.zip       binary
